+const (
+	firstTrackedDialTCPPort = uint16(56000)
+	lastTrackedDialTCPPort  = uint16(60999)
+)
+
+type trackedDialTCPConn struct {
+	*gonet.TCPConn
+	closeOnce sync.Once
+	release   func()
+}
+
+func (c *trackedDialTCPConn) Close() error {
+	err := c.TCPConn.Close()
+	c.closeOnce.Do(c.release)
+	return err
+}
+
+func (ns *Impl) reserveDialTCPPort(localAddr netip.Addr) (netip.AddrPort, bool) {
+	ns.mu.Lock()
+	defer ns.mu.Unlock()
+	portCount := int(lastTrackedDialTCPPort-firstTrackedDialTCPPort) + 1
+	for range portCount {
+		port := ns.nextDialTCPPort
+		ns.nextDialTCPPort++
+		if ns.nextDialTCPPort > lastTrackedDialTCPPort {
+			ns.nextDialTCPPort = firstTrackedDialTCPPort
+		}
+		address := netip.AddrPortFrom(localAddr, port)
+		if _, exists := ns.dialedTCPPorts[address]; exists {
+			continue
+		}
+		ns.dialedTCPPorts[address] = struct{}{}
+		return address, true
+	}
+	return netip.AddrPort{}, false
+}
+
+func (ns *Impl) releaseDialTCPPort(address netip.AddrPort) {
+	ns.mu.Lock()
+	delete(ns.dialedTCPPorts, address)
+	ns.mu.Unlock()
+}
+
+func (ns *Impl) isDialedTCPPort(address netip.AddrPort) bool {
+	ns.mu.Lock()
+	_, ok := ns.dialedTCPPorts[address]
+	ns.mu.Unlock()
+	return ok
+}
+
+// DialContextTCPWithTrackedBind dials from a reserved userspace-netstack
+// source port. The inbound hook can then return only this connection's
+// packets to netstack while preserving external-TUN traffic for other apps.
+func (ns *Impl) DialContextTCPWithTrackedBind(ctx context.Context, localAddr netip.Addr, remoteAddr netip.AddrPort) (net.Conn, error) {
+	localAddress, ok := ns.reserveDialTCPPort(localAddr)
+	if !ok {
+		return nil, errors.New("no tracked netstack TCP ports available")
+	}
+	release := func() { ns.releaseDialTCPPort(localAddress) }
+	remoteAddress := tcpip.FullAddress{
+		NIC:  nicID,
+		Addr: tcpip.AddrFromSlice(remoteAddr.Addr().AsSlice()),
+		Port: remoteAddr.Port(),
+	}
+	boundAddress := tcpip.FullAddress{
+		NIC:  nicID,
+		Addr: tcpip.AddrFromSlice(localAddr.AsSlice()),
+		Port: localAddress.Port(),
+	}
+	var ipType tcpip.NetworkProtocolNumber
+	if remoteAddr.Addr().Is4() {
+		ipType = ipv4.ProtocolNumber
+	} else {
+		ipType = ipv6.ProtocolNumber
+	}
+	connection, err := gonet.DialTCPWithBind(ctx, ns.ipstack, boundAddress, remoteAddress, ipType)
+	if err != nil {
+		release()
+		return nil, err
+	}
+	return &trackedDialTCPConn{TCPConn: connection, release: release}, nil
+}
