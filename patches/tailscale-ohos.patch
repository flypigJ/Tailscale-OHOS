+func TestTrackedDialTCPPortLifecycle(t *testing.T) {
+	localAddr := netip.MustParseAddr("100.64.0.1")
+	impl := &Impl{
+		dialedTCPPorts:  make(map[netip.AddrPort]struct{}),
+		nextDialTCPPort: firstTrackedDialTCPPort,
+	}
+
+	reserved, ok := impl.reserveDialTCPPort(localAddr)
+	if !ok {
+		t.Fatal("reserveDialTCPPort unexpectedly failed")
+	}
+	if got, want := reserved.Port(), firstTrackedDialTCPPort; got != want {
+		t.Fatalf("reserved port = %d, want %d", got, want)
+	}
+	if !impl.isDialedTCPPort(reserved) {
+		t.Fatal("reserved port is not tracked")
+	}
+	impl.releaseDialTCPPort(reserved)
+	if impl.isDialedTCPPort(reserved) {
+		t.Fatal("released port remains tracked")
+	}
+
+	impl.nextDialTCPPort = lastTrackedDialTCPPort
+	last, ok := impl.reserveDialTCPPort(localAddr)
+	if !ok || last.Port() != lastTrackedDialTCPPort {
+		t.Fatalf("last reservation = %v, %v", last, ok)
+	}
+	wrapped, ok := impl.reserveDialTCPPort(localAddr)
+	if !ok || wrapped.Port() != firstTrackedDialTCPPort {
+		t.Fatalf("wrapped reservation = %v, %v", wrapped, ok)
+	}
+}
